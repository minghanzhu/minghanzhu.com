---
import ExperienceCard from "../components/ExperienceCard.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import TagList from "../components/TagList.astro";
import { education, experience, profile, publications, research, skills } from "../data/profile";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Resume | Minghan (Max) Zhu"
  description="Resume for Minghan (Max) Zhu, UCSF Neurology research engineer and Associate Specialist building ML/data infrastructure, neural signal models, and clinical research software for adaptive DBS."
>
  <SiteHeader />

  <main>
    <section class="resume-hero content-grid">
      <div>
        <p class="eyebrow">Resume</p>
        <h1>{profile.name}</h1>
        <p class="lede">{profile.role}</p>
        <p class="affiliation-line">
          Associated with{" "}
          <a href={profile.affiliations[0].url}>{profile.affiliations[0].name}</a>
        </p>
      </div>
      <div class="resume-actions">
        <a class="button primary" href={`mailto:${profile.email}`}>{profile.email}</a>
        <a class="button ghost" href={profile.linkedin}>LinkedIn</a>
      </div>
    </section>

    <section class="content-grid resume-layout">
      <aside class="resume-sidebar">
        <div class="compact-card">
          <h2>Education</h2>
          {education.map((item) => (
            <div class="resume-block">
              <h3>{item.school}</h3>
              <p class="muted">{item.location}</p>
              <ul class="clean-list">
                {item.credentials.map((credential) => <li>{credential}</li>)}
              </ul>
            </div>
          ))}
        </div>

        <div class="compact-card">
          <h2>Skills</h2>
          {skills.map((group) => (
            <div class="resume-block">
              <h3>{group.group}</h3>
              <TagList items={group.items} />
            </div>
          ))}
        </div>
      </aside>

      <div class="resume-main">
        <section>
          <div class="section-heading tight">
            <p class="eyebrow">Publications</p>
            <h2>Neural decoding, abstracts, and patent work</h2>
          </div>
          <div class="publication-list">
            {publications.map((item) => (
              <article class="compact-card publication-card">
                <p class="eyebrow">{item.type} · {item.dates}</p>
                <h3><a href={item.url}>{item.title}</a></h3>
                <p class="muted">{item.venue}</p>
                <p class="muted">{item.authors}</p>
                <p>{item.summary}</p>
              </article>
            ))}
          </div>
        </section>

        <section>
          <div class="section-heading tight">
            <p class="eyebrow">Experience</p>
            <h2>Research engineering and applied ML work</h2>
          </div>
          <div class="experience-grid">
            {experience.map((item) => <ExperienceCard item={item} />)}
          </div>
        </section>

        <section>
          <div class="section-heading tight">
            <p class="eyebrow">Research</p>
            <h2>Research roles and projects</h2>
          </div>
          <div class="research-list">
            {research.map((item) => (
              <article class="compact-card">
                <p class="eyebrow">{item.dates}</p>
                <h3>{item.title}</h3>
                <p class="muted">{item.lab} · {item.context}</p>
                <p>{item.summary}</p>
              </article>
            ))}
          </div>
        </section>

      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
