---
import ExperienceCard from "../components/ExperienceCard.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import TagList from "../components/TagList.astro";
import { education, experience, profile, publications, research, skills } from "../data/profile";
import BaseLayout from "../layouts/BaseLayout.astro";

const currentExperience = experience[0];
const selectedExperience = experience.slice(0, 5);
---

<BaseLayout>
  <SiteHeader />

  <main>
    <section class="intro-shell">
      <img src={profile.heroImage} alt="" class="intro-art" loading="eager" />
      <div class="intro-overlay"></div>
      <div class="content-grid intro-content">
        <div class="intro-copy">
          <img src={profile.profileImage} alt={profile.profileImageAlt} class="intro-profile-photo" loading="eager" />
          <p class="eyebrow">{profile.location}</p>
          <h1>{profile.name}</h1>
          <p class="lede">{profile.role}</p>
          <p class="affiliation-line">
            Associated with{" "}
            <a href={profile.affiliations[0].url}>{profile.affiliations[0].name}</a>
          </p>
          <p class="intro-text">{profile.intro}</p>
          <div class="button-row" aria-label="Profile links">
            <a class="button primary" href="/resume/">View CV</a>
            <a class="button ghost" href={profile.linkedin}>LinkedIn</a>
          </div>
        </div>
        <aside class="current-panel" aria-label="Current research focus">
          <img
            src={profile.diagramImage}
            alt="Illustration of a deep brain stimulation system with implanted brain leads and an external controller."
            class="panel-image"
            loading="eager"
          />
          <p class="eyebrow">Current research</p>
          <h2>{currentExperience.company}</h2>
          <p class="muted">{currentExperience.title}</p>
          <p class="muted">
            <a href={profile.affiliations[0].url}>{profile.affiliations[0].name}</a>
          </p>
          <p>{currentExperience.summary}</p>
          <TagList items={currentExperience.tags} />
        </aside>
      </div>
    </section>

    <section class="content-grid section-band split-section" id="publications">
      <div class="section-heading">
        <p class="eyebrow">Publications</p>
        <h2>Neural decoding posters, conference abstracts, and patent work.</h2>
      </div>
      <div class="publication-list">
        {publications.map((item) => (
          <article class="compact-card publication-card">
            <p class="eyebrow">{item.type} · {item.dates}</p>
            <h3><a href={item.url}>{item.title}</a></h3>
            <p class="muted">{item.venue}</p>
            <p class="muted">{item.authors}</p>
            <p>{item.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-grid section-band">
      <div class="section-heading">
        <p class="eyebrow">Profile</p>
        <h2>Research software for neural signals, adaptive DBS, and applied ML.</h2>
      </div>
      <div class="focus-grid">
        {profile.focus.map((item) => <p>{item}</p>)}
      </div>
    </section>

    <section class="metric-band" aria-label="Selected impact">
      <div class="content-grid metric-grid">
        {profile.quickStats.map((stat) => (
          <article>
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-grid section-band" id="work">
      <div class="section-heading">
        <p class="eyebrow">Experience</p>
        <h2>Research engineering across neuroscience, healthcare data, and applied ML systems.</h2>
      </div>
      <div class="experience-grid">
        {selectedExperience.map((item) => <ExperienceCard item={item} />)}
      </div>
      <div class="section-action">
        <a class="button" href="/resume/">Read full resume</a>
      </div>
    </section>

    <section class="content-grid section-band split-section" id="research">
      <div class="section-heading">
        <p class="eyebrow">Research</p>
        <h2>Current and past research in neural signals, IoT systems, and language/computer vision.</h2>
      </div>
      <div class="research-list">
        {research.map((item) => (
          <article class="compact-card">
            <p class="eyebrow">{item.dates}</p>
            <h3>{item.title}</h3>
            <p class="muted">{item.lab} · {item.context}</p>
            <p>{item.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-grid section-band split-section">
      <div class="section-heading">
        <p class="eyebrow">Education</p>
        <h2>Computer science training at Columbia and Brandeis.</h2>
      </div>
      <div class="education-list">
        {education.map((item) => (
          <article class="compact-card">
            <h3>{item.school}</h3>
            <p class="muted">{item.location}</p>
            <ul class="clean-list">
              {item.credentials.map((credential) => <li>{credential}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="content-grid section-band">
      <div class="section-heading">
        <p class="eyebrow">Technical Stack</p>
        <h2>Comfortable from experimental analysis to deployed research infrastructure.</h2>
      </div>
      <div class="skills-grid">
        {skills.map((group) => (
          <article class="skill-card">
            <h3>{group.group}</h3>
            <TagList items={group.items} />
          </article>
        ))}
      </div>
    </section>

    <section class="contact-band">
      <div class="content-grid contact-grid">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Open to research engineering and scientific ML conversations.</h2>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={`mailto:${profile.email}`}>Email</a>
          <a class="button" href={profile.linkedin}>LinkedIn</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
