---
import TagList from "./TagList.astro";

interface Props {
  item: {
    company: string;
    location: string;
    title: string;
    dates: string;
    summary: string;
    bullets: string[];
    tags: string[];
  };
}

const { item } = Astro.props;
---

<article class="experience-card">
  <div class="experience-heading">
    <div>
      <p class="eyebrow">{item.dates}</p>
      <h3>{item.title}</h3>
      <p class="muted">{item.company} · {item.location}</p>
    </div>
  </div>
  <p class="experience-summary">{item.summary}</p>
  <ul class="clean-list">
    {item.bullets.map((bullet) => <li>{bullet}</li>)}
  </ul>
  <TagList items={item.tags} />
</article>
